{
  "rewrites": [
    {
      "source": "/api/ncm/(.*)",
      "destination": "https://ncm-api.prod.gbclstudio.cn/$1"
    },
    {
      "source": "/api/la/(.*)",
      "destination": "https://lyric-atlas-api.vercel.app/$1"
    },
    {
      "source": "/api/unm/(.*)",
      "destination": "https://unm-api.prod.gbclstudio.cn/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "installCommand": "rustup target add wasm32-unknown-unknown && pnpm install:with-deps",
  "buildCommand": "pnpm build"
}
